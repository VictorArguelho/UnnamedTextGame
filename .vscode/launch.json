{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Launch Game",
            "type": "coreclr",
            "request": "launch",
            "program": "dotnet",
            "args": [
                "${workspaceFolder}/bin/Debug/net11.0/UnnamedTextGame.dll"
            ],
            "cwd": "${workspaceFolder}",
            "console": "externalTerminal",
            "stopAtEntry": false
        }
    ]
}